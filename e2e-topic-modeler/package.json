{
  "name": "e2e-topic-modeler",
  "version": "1.0.0",
  "description": "Embedding-to-Explanation Topic Modeler — a hybrid analytic tool for text topic modeling",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev public/ --port 8788",
